# Sentifix — production env for docker-compose.prod.yml (single-server / AWS EC2)
# Copy to .env.prod and fill in the REQUIRED values. Do NOT commit .env.prod.
#
#   cp .env.prod.example .env.prod

NODE_ENV=production
PORT=3000

# Host port the app is published on. Default 80 (dedicated server).
# On a shared box where 80 is taken (e.g. by another app's nginx), set a free port
# like 8080 — the webhook URL then becomes http://<IP>:8080/webhooks/github
# SENTIFIX_APP_PORT=8080

# Create entity tables on first boot (entity tables have no migrations).
# Migrations create the pgvector extension + code_chunks automatically.
DB_SYNCHRONIZE=true

# ── Internal service URLs (hostnames = docker-compose service names) ──────────
# These point at the containers on the internal network — do not change the hosts.
DATABASE_URL=postgresql://sentifix:secret@postgres:5432/sentifix
REDIS_URL=redis://redis:6379
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# If you set custom datastore credentials below, update the URLs above to match.
POSTGRES_PASSWORD=secret
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── OpenAI (REQUIRED) ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── GitHub (REQUIRED: webhook secret) ─────────────────────────────────────────
# Generate a strong secret: `openssl rand -hex 32`  — must match your GitHub webhook.
GITHUB_WEBHOOK_SECRET=changeme
# Optional PAT — for private repos / higher rate limits (not needed if using a GitHub App)
# GITHUB_TOKEN=ghp_...

# Which issues to auto-triage (protects LLM spend on busy repos):
#   all | label:<name> | command   (default: all)
# "/sentifix" issue comment always triggers a (re)triage. Subscribe the webhook to
# "Issue comments" events to use command/manual triggering.
# SENTIFIX_TRIGGER=all

# ── API auth (optional — require X-Api-Key on /triage and /index) ─────────────
# API_KEY=your-secret-key

# ── GitHub App (optional — one-click multi-repo install) ──────────────────────
# GITHUB_APP_ID=123456
# GITHUB_APP_SLUG=sentifix-bot
# GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# GITHUB_APP_CLIENT_ID=Iv1.abc123
# GITHUB_APP_CLIENT_SECRET=abc123

# ── Slack (optional) ──────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=abc123
# SLACK_DEFAULT_REPO=owner/repo
