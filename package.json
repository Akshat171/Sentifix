{
  "name": "sentifix",
  "version": "0.1.0",
  "description": "AI agent that triages GitHub bug reports and proposes fixes",
  "license": "MIT",
  "private": false,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.build.tsbuildinfo && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "rm -rf dist tsconfig.build.tsbuildinfo && nest start --watch",
    "start:debug": "rm -rf dist tsconfig.build.tsbuildinfo && nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs",
    "test:pipeline": "ts-node -r tsconfig-paths/register scripts/test-pipeline.ts",
    "simulate:webhook": "bash scripts/simulate-webhook.sh"
  },
  "dependencies": {
    "@fastify/static": "^8.0.4",
    "@langchain/langgraph": "^0.2.35",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/microservices": "^10.4.15",
    "@nestjs/platform-fastify": "^10.4.15",
    "@nestjs/terminus": "^10.2.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.2",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^21.1.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@slack/web-api": "^7.17.0",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^0.10.5",
    "diff": "^9.0.0",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.2",
    "joi": "^17.13.3",
    "openai": "^4.104.0",
    "pg": "^8.13.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/amqplib": "^0.10.5",
    "@types/diff": "^8.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.17",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
