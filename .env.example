NODE_ENV=development
PORT=3000

# PostgreSQL (pgvector image)
DATABASE_URL=postgresql://sentifix:secret@localhost:5433/sentifix
# In production (NODE_ENV=production), TypeORM synchronize is off. Set this to true so the
# app creates its entity tables on first boot (entity tables have no migrations). Managed
# deploys (see render.yaml / DEPLOY.md) set this automatically. Leave unset for local dev.
# DB_SYNCHRONIZE=false

# Redis
REDIS_URL=redis://localhost:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# GitHub
GITHUB_WEBHOOK_SECRET=changeme
# GITHUB_TOKEN=ghp_...   (optional, avoids rate limits and enables private repos)

# Which issues to auto-triage (protects your LLM spend on busy repos):
#   all           = every opened/reopened issue (default)
#   label:bug     = only issues with the "bug" label
#   command       = none automatically; only when someone comments "/sentifix"
# A "/sentifix" issue comment always triggers a (re)triage regardless of this.
# Requires the webhook to subscribe to "Issue comments" events for command/manual use.
# SENTIFIX_TRIGGER=all

# REST API auth — if set, all /triage and /index endpoints require X-Api-Key header
# API_KEY=your-secret-key

# ── Multi-tenant SaaS mode (optional) ─────────────────────────────────────────
# When true, the dashboard/setup/API require GitHub login and show each user only
# their own installations' data. Leave false for open single-tenant self-hosting.
# Needs a GitHub App with an OAuth callback at <APP_BASE_URL>/auth/callback.
# DASHBOARD_AUTH=false
# SESSION_SECRET=            # long random string; openssl rand -hex 32
# APP_BASE_URL=https://your-domain.com

# ── Slack integration (optional — enables @sentifix mentions in channels) ──────
# Create at: api.slack.com/apps → Create New App → From Scratch
# Bot Token Scopes: app_mentions:read, chat:write, chat:write.public
# Event Subscriptions: app_mention → Request URL: https://your-domain/webhooks/slack
#
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=abc123
# SLACK_DEFAULT_REPO=your-org/your-repo   # fallback when repo not mentioned

# ── Rate limiting ───────────────────────────────────────────────────────────────
# Default: 60 requests/minute per IP across all non-webhook endpoints.
# Webhook endpoints (/webhooks/github, /webhooks/slack) are always exempt.

# ── OpenTelemetry tracing (optional) ────────────────────────────────────────────
# Set OTEL_ENABLED=true to ship traces to any OTLP-compatible backend
# (Jaeger, Grafana Tempo, Honeycomb, Datadog, etc.)
#
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=sentifix
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# ── GitHub App (optional — enables one-click install instead of manual webhooks) ──
# Create at: https://github.com/settings/apps/new
# Required permissions: Issues (R/W), Pull Requests (W), Contents (W), Metadata (R)
# Required events: installation, installation_repositories, issues, push
# Webhook URL: https://your-domain.com/webhooks/github
#
# GITHUB_APP_ID=123456
# GITHUB_APP_SLUG=sentifix-bot          # the app's slug from its GitHub URL
# GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEo...\n-----END RSA PRIVATE KEY-----
# GITHUB_APP_CLIENT_ID=Iv1.abc123
# GITHUB_APP_CLIENT_SECRET=abc123
